    "@pact-foundation/pact": "^13.2.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/kafka": "^11.14.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "axios": "^1.16.0",
    "bcrypt": "^5.1.1",
