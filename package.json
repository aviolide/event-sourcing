  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e-auth e2e-wallet e2e-payments e2e-gateway --runInBand",
    "test:e2e:auth": "jest --selectProjects e2e-auth --runInBand",
    "test:e2e:wallet": "jest --selectProjects e2e-wallet --runInBand",
    "test:e2e:payments": "jest --selectProjects e2e-payments --runInBand",
    "test:e2e:gateway": "jest --selectProjects e2e-gateway --runInBand",
    "test:e2e:platform": "jest --selectProjects e2e-platform --runInBand",
    "test:contracts": "jest --selectProjects contracts",
    "test:chaos": "jest --selectProjects chaos",
    "test:performance": "jest --selectProjects performance",
    "test:all": "jest",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
