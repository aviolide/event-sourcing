                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Deposit($input: DepositInput!) {\n  deposit(input: $input) {\n    success\n    message\n    transaction {\n      id\n      walletId\n      type\n      amount\n      currency\n      status\n      description\n      createdAt\n    }\n    wallet {\n      id\n      balance\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"walletId\": \"{{walletId}}\",\n    \"amount\": 100.00,\n    \"currency\": \"USD\",\n    \"description\": \"Test deposit via Postman\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Add funds to wallet (simulated deposit operation)."
          }
        },
        {
          "name": "Withdraw Funds",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
