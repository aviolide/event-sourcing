              "mode": "graphql",
              "graphql": {
                "query": "query IntrospectionQuery {\n  __schema {\n    queryType { name }\n    mutationType { name }\n    types {\n      kind\n      name\n      description\n      fields {\n        name\n        description\n        type { name kind }\n      }\n    }\n  }\n}",
                "variables": "{}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
