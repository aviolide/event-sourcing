            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreatePaymentIntent($input: CreatePaymentIntentInput!) {\n  createPaymentIntent(input: $input) {\n    success\n    paymentIntent {\n      id\n      amount\n      currency\n      status\n      recipientWalletId\n      metadata\n      createdAt\n      expiresAt\n    }\n    clientSecret\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"amount\": 49.99,\n    \"currency\": \"USD\",\n    \"recipientWalletId\": \"{{walletId}}\",\n    \"description\": \"Test payment for premium subscription\",\n    \"metadata\": {\n      \"orderId\": \"ORD-{{timestamp}}\",\n      \"productId\": \"PROD-PREMIUM-001\"\n    }\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Create a payment intent for processing (Stripe-like pattern)."
          }
        },
        {
          "name": "Transfer Between Wallets",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
