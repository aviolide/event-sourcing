            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query ListTransactions($walletId: ID!, $page: Int, $limit: Int, $type: TransactionType) {\n  transactions(walletId: $walletId, page: $page, limit: $limit, type: $type) {\n    totalCount\n    page\n    limit\n    items {\n      id\n      type\n      amount\n      currency\n      status\n      description\n      counterpartyWalletId\n      createdAt\n      completedAt\n    }\n  }\n}",
                "variables": "{\n  \"walletId\": \"{{walletId}}\",\n  \"page\": 1,\n  \"limit\": 20,\n  \"type\": null\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Paginated transaction history for a wallet with optional type filter."
