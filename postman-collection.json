  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Register($input: RegisterInput!) {\n  register(input: $input) {\n    success\n    message\n    user {\n      id\n      email\n      fullName\n      phone\n      createdAt\n    }\n    tokens {\n      accessToken\n      refreshToken\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"fullName\": \"Test User {{timestamp}}\",\n    \"email\": \"testuser{{timestamp}}@digitalwallet.test\",\n    \"phone\": \"+1234567890\",\n    \"password\": \"SecureP@ssw0rd!2026\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Register a new user with email, phone, and password. Returns JWT tokens and user profile."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  if (res.data?.register?.success) {",
                  "    pm.collectionVariables.set('accessToken', res.data.register.tokens.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', res.data.register.tokens.refreshToken);",
                  "    pm.collectionVariables.set('userId', res.data.register.user.id);",
                  "    console.log('✅ Registered:', res.data.register.user.email);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    success\n    message\n    user {\n      id\n      email\n      fullName\n      phone\n    }\n    tokens {\n      accessToken\n      refreshToken\n      expiresIn\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"identifier\": \"testuser{{timestamp}}@digitalwallet.test\",\n    \"password\": \"SecureP@ssw0rd!2026\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Authenticate user with email/phone and password. Returns JWT access and refresh tokens."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  if (res.data?.login?.success) {",
                  "    pm.collectionVariables.set('accessToken', res.data.login.tokens.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', res.data.login.tokens.refreshToken);",
                  "    pm.collectionVariables.set('userId', res.data.login.user.id);",
                  "    console.log('✅ Logged in as:', res.data.login.user.email);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RefreshToken($input: RefreshTokenInput!) {\n  refreshToken(input: $input) {\n    success\n    tokens {\n      accessToken\n      refreshToken\n      expiresIn\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"refreshToken\": \"{{refreshToken}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Exchange refresh token for new access token pair."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Me {\n  me {\n    id\n    email\n    fullName\n    phone\n    isVerified\n    createdAt\n    updatedAt\n  }\n}",
                "variables": "{}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Fetch authenticated user profile (requires valid JWT)."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Logout {\n  logout {\n    success\n    message\n  }\n}",
                "variables": "{}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Invalidate current refresh token and logout user."
          }
        }
      ]
    },
    {
      "name": "💰 Wallet Operations",
      "item": [
        {
