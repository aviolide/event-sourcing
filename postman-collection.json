            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Withdraw($input: WithdrawInput!) {\n  withdraw(input: $input) {\n    success\n    message\n    transaction {\n      id\n      walletId\n      type\n      amount\n      currency\n      status\n      description\n      createdAt\n    }\n    wallet {\n      id\n      balance\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"walletId\": \"{{walletId}}\",\n    \"amount\": 25.50,\n    \"currency\": \"USD\",\n    \"description\": \"Test withdrawal via Postman\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Withdraw funds from wallet (requires sufficient balance)."
          }
