            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation TransferFunds($input: TransferInput!) {\n  transferFunds(input: $input) {\n    success\n    message\n    transfer {\n      id\n      fromWalletId\n      toWalletId\n      amount\n      currency\n      status\n      description\n      createdAt\n      completedAt\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"fromWalletId\": \"{{walletId}}\",\n    \"toWalletId\": \"WALLET-TEST-RECIPIENT-001\",\n    \"amount\": 15.00,\n    \"currency\": \"USD\",\n    \"description\": \"P2P transfer test via Postman\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
