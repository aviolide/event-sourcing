    },
    {
      "name": "💳 Payments & Transfers",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
