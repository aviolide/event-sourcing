            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateWallet($input: CreateWalletInput!) {\n  createWallet(input: $input) {\n    success\n    message\n    wallet {\n      id\n      userId\n      currency\n      balance\n      status\n      createdAt\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"currency\": \"USD\",\n    \"initialBalance\": 0\n  }\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Create a new wallet for the authenticated user.",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "  const res = pm.response.json();",
                    "  if (res.data?.createWallet?.success) {",
                    "    pm.collectionVariables.set('walletId', res.data.createWallet.wallet.id);",
                    "    console.log('✅ Wallet created:', res.data.createWallet.wallet.id);",
                    "  }",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
        {
          "name": "Get Wallet Balance",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetWallet($walletId: ID!) {\n  wallet(walletId: $walletId) {\n    id\n    userId\n    currency\n    balance\n    status\n    transactions {\n      id\n      type\n      amount\n      description\n      status\n      createdAt\n    }\n    createdAt\n    updatedAt\n  }\n}",
                "variables": "{\n  \"walletId\": \"{{walletId}}\"\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Fetch wallet details including balance and transaction history."
          }
        },
        {
          "name": "List User Wallets",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
