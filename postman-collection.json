    "description": "GraphQL API collection for the NestJS Digital Wallet microservices platform. Includes Auth, Wallet, and Payments operations with test entities."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/graphql",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
