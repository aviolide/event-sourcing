            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query ListWallets($page: Int, $limit: Int) {\n  wallets(page: $page, limit: $limit) {\n    totalCount\n    page\n    limit\n    items {\n      id\n      currency\n      balance\n      status\n      createdAt\n    }\n  }\n}",
                "variables": "{\n  \"page\": 1,\n  \"limit\": 10\n}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Paginated list of all wallets for authenticated user."
          }
        },
        {
          "name": "Deposit Funds",
          "request": {
            "auth": {
